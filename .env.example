# Copiar a .env.local y ajustar. Next.js NO lee este archivo solo: es plantilla.
# Ver también src/config/env.ts (valores por defecto en desarrollo).

# API de reservas (booking-app/api, puerto por defecto 7070)
NEXT_PUBLIC_RESERVAS_API_BASE=http://localhost:7070
# API del PMS core
NEXT_PUBLIC_CORE_API_URL=http://localhost:3030
